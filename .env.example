# Optional OpenRouter OCR 보완 모드
# 비워두면 로컬/OFFLINE OCR(또는 기능별 기본 경로)만 사용되며 웹 OCR 고정밀 경로는 비활성화됩니다.
# API key: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_api_key_here

# Optional: Set a specific model (Default: google/gemma-3-27b-it:free)
# VITE_OPENROUTER_MODEL=google/gemma-3-27b-it:free
